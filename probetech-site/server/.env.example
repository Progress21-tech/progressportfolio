# Copy this file to .env and fill in real values. NEVER commit .env.

# Supabase — from your project's API settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — sign up free at resend.com, create an API key
RESEND_API_KEY=re_your_key_here
NOTIFY_TO=hello@yourdomain.com
# Until you verify a domain in Resend, you can use their test sender:
NOTIFY_FROM=Portfolio <onboarding@resend.dev>

# Comma-separated list of frontends allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173,https://your-site.vercel.app

# Render sets PORT automatically; locally it defaults to 5000
PORT=5000
